# ─────────────────────────────────────────────────────────────────────────────
# job-sentinel — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
#
#  Copy this file to .env and fill in your values:
#
#    cp .env.example .env
#
#  NEVER commit .env to version control — it is in .gitignore.
#  All values here are safe defaults / placeholders only.
#
# ─────────────────────────────────────────────────────────────────────────────


# ┌─────────────────────────────────────────────────────────────────────────┐
# │  TELEGRAM                                                               │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Step 1 — Create a bot via @BotFather on Telegram, copy the token below.
# Step 2 — Message your bot once, then visit:
#           https://api.telegram.org/bot<TOKEN>/getUpdates
#           to find your chat_id.
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ┌─────────────────────────────────────────────────────────────────────────┐
# │  SITE ADAPTER                                                           │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Built-in adapter IDs:
#   12twenty      →  UTD / university 12twenty portals
#   handshake     →  Handshake (joinhandshake.com)
#   simplicity    →  Simplicity ATS
#   greenhouse    →  Greenhouse job boards
#   custom        →  Your own adapter (set CUSTOM_ADAPTER_PATH below)
#
# To add a new site: see docs/design/adapter-authoring.md
#
SITE_ADAPTER=12twenty

# Only required when SITE_ADAPTER=custom
# CUSTOM_ADAPTER_PATH=src/job_sentinel/adapters/sites/my_site.py


# ┌─────────────────────────────────────────────────────────────────────────┐
# │  PORTAL CREDENTIALS                                                     │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Username and password for the job portal being monitored.
# These are only ever stored in your local .env — never sent anywhere
# except the target portal during login.
#
PORTAL_USERNAME=
PORTAL_PASSWORD=

# The full URL to the job listings page to monitor.
# 12twenty example (UTD):
PORTAL_JOBS_URL=https://utdallas.12twenty.com/jobPostings#/jobPostings/index?viewId=6&tab=studentEmployment
# Handshake example:
# PORTAL_JOBS_URL=https://app.joinhandshake.com/stu/postings


# ┌─────────────────────────────────────────────────────────────────────────┐
# │  SCRAPER BEHAVIOUR                                                      │
# └─────────────────────────────────────────────────────────────────────────┘

# How often to poll the portal (seconds). Default: 900 (15 min).
POLL_INTERVAL_SECONDS=900

# Run browser in headless mode? Set false to watch the browser for debugging.
HEADLESS=true

# Slow Playwright actions for debugging (ms). Use 0 in production.
BROWSER_SLOWMO_MS=0

# Max result pages to paginate through per cycle.
MAX_PAGES=50

# Request timeout per page load (ms).
PAGE_TIMEOUT_MS=30000


# ┌─────────────────────────────────────────────────────────────────────────┐
# │  KEYWORD FILTERING                                                      │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Comma-separated list. A posting must match at least one keyword to trigger
# an alert. Leave empty to alert on ALL postings.
#
KEYWORD_FILTERS=software,engineer,developer,research assistant,teaching assistant,data,analyst


# ┌─────────────────────────────────────────────────────────────────────────┐
# │  PERSISTENCE                                                            │
# └─────────────────────────────────────────────────────────────────────────┘

# Path to the SQLite database file. Relative = project root.
DB_PATH=data/jobs.db


# ┌─────────────────────────────────────────────────────────────────────────┐
# │  LOGGING                                                                │
# └─────────────────────────────────────────────────────────────────────────┘

# Log level: TRACE | DEBUG | INFO | SUCCESS | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Directory for rotating log files.
LOG_DIR=logs

# Emit logs as JSON (useful for log aggregators like Loki / Datadog).
LOG_JSON=false


# ┌─────────────────────────────────────────────────────────────────────────┐
# │  MISC                                                                   │
# └─────────────────────────────────────────────────────────────────────────┘

# Dry run — scrape and log but do NOT send Telegram messages.
# Great for first-run testing without spamming yourself.
DRY_RUN=false

# Environment name: development | staging | production
ENV=development
